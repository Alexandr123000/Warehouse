<Window x:Class="Warehouse.ProductsSelling"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Warehouse"
        mc:Ignorable="d"
        Title="ProductsSelling" Height="370" Width="500" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Height="330" Width="480" Margin="0,0,0,0">

        <Label Content="Current Balance:" FontSize="12" Margin="334,3,-6,234"/>
        <Label Name="CurrentBalanceLabel" Content="---" FontSize="12" Margin="423,3,-31,250"/>



        <Label Content="Product Name" Margin="0,0,296,304" Height="26"/>
        <TextBox Name="NameOfSellingProductTextBox" Margin="0,26,296,278" Height="26"/>
        <Label Content="Product Type" Margin="0,57,296,247" Height="26"/>
        <TextBox Name="TypeOfSellingProductTextBox" Margin="0,83,296,221" Height="26"/>
        <Label Content="Product Price" Margin="0,114,296,190" Height="26"/>
        <TextBox Name="PriceSellingProductTextBox" Margin="0,140,296,164" Height="26"/>
        <Label Content="Quatity" Margin="0,171,296,133" Height="26"/>
        <TextBox Name="ProductQuantityTextBox" Margin="0,197,296,107" Height="26"/>

        <Button Name="ProductSellingButton" Content="Sell Product" Margin="10,286,328,13"/>
        <Button Name="CancelProductSellingButton" Content="Cancel" Margin="401,286,10,13"/>
    </Grid>
</Window>
